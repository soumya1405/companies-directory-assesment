{
  "version": 3,
  "name": "companies-directory",
  "projects": [
    {
      "src": "front-end/companies-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "back-end/$1.js"
    }
  ]
}