{
  "version": 5,
  "name": "companies-directory",
  "builds": [
    {
      "src": "front-end/companies-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "back-end/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "back-end/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "front-end/companies-frontend/$1"
    }
  ]
}